{
  "name": "@northkeep/web",
  "version": "0.4.0",
  "description": "NorthKeep local GUI: token-authed loopback server + single-file web UI",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/static && cp static/index.html dist/static/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@northkeep/core": "workspace:*",
    "@northkeep/extract": "workspace:*",
    "@northkeep/importers": "workspace:*",
    "@northkeep/librarian": "workspace:*",
    "@northkeep/mcp-server": "workspace:*",
    "@northkeep/redact": "workspace:*",
    "@northkeep/converse": "workspace:*",
    "@northkeep/sync": "workspace:*"
  }
}
